alias sudo='sudo '
alias ls='ls -F --color'
alias rm='rm -v -I'
alias mv='mv -vi'
alias cp='cp -vi'
alias grep='grep --color=auto'
alias md='mkdir'
alias py='python'
alias cmatrix='cmatrix -b'
alias icat='kitten icat'
alias tree='tree -C'
alias cls='clear'
alias cowsay='cowsay -f sus'
alias sl='sl -ec10w'

alias syssuspend='systemctl suspend'

alias full-upgrade.sh='systemd-inhibit --what=sleep --why="Upgrading system" --who=full-upgrade.sh full-upgrade.sh'

alias patch-vencord='sh -c "$(curl -sS https://raw.githubusercontent.com/Vendicated/VencordInstaller/main/install.sh)"'

